# --- GitHub App credentials ---
# Create a GitHub App at https://github.com/settings/apps/new
GITHUB_APP_ID=
# Either paste the PEM directly here with \n for newlines, or use the path option below
GITHUB_PRIVATE_KEY=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
GITHUB_WEBHOOK_SECRET=

# Used by `npm run smee` for local webhook forwarding.
# Get one at https://smee.io/new
SMEE_URL=

# --- Gemini API ---
GEMINI_API_KEY=
GEMINI_REVIEW_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Database ---
# Matches docker-compose.yml defaults
DATABASE_URL=postgres://reviewpilot:reviewpilot@localhost:5432/reviewpilot

# --- Server ---
PORT=3000
